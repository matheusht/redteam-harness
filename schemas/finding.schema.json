{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "finding",
  "description": "An oracle-validated issue instance. Few. Status mutable WITH review history.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "engagement", "owasp", "surface", "objective", "scope_class", "severity", "confidence", "attempt_id", "control_attempt_id", "oracle_verdict", "dedup_key", "status"],
  "properties": {
    "id": { "type": "string" },
    "engagement": { "type": "string" },
    "owasp": { "type": "string" },
    "atlas": { "type": "string", "description": "MITRE ATLAS cross-walk" },
    "surface": { "type": "string" },
    "objective": { "type": "string", "description": "the benign proxy, e.g. disclosure_proof" },
    "scope_class": { "enum": ["proxy_safe", "operator_only", "forbidden"] },
    "safety_class": { "type": "string", "description": "e.g. benign_disclosure" },
    "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
    "confidence": {
      "enum": ["confirmed", "needs_review", "contaminated", "rejected"],
      "description": "black-box 'confirmed' = consistent-and-specific, NOT diffed-against-truth"
    },
    "attempt_id": { "type": "string", "description": "the primary attempt" },
    "control_attempt_id": { "type": "string", "description": "the matched negative control (must have refused)" },
    "positive_control_attempt_id": { "type": ["string", "null"], "description": "known-trigger proving the oracle can detect success" },
    "replay_attempt_ids": { "type": "array", "items": { "type": "string" } },
    "leaked_fragments": { "type": "array", "items": { "type": "string" }, "description": "distinctive tokens only; redact secrets" },
    "oracle_verdict": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signal": { "type": "boolean" },
        "adjudication": { "type": "boolean" },
        "contamination_ruled_out": { "type": "boolean" },
        "note": { "type": "string", "description": "the one sentence why it's real" }
      },
      "required": ["signal", "adjudication", "contamination_ruled_out"]
    },
    "dedup_key": { "type": "string", "description": "owasp|surface|signal-type|preconditions" },
    "status": { "enum": ["open", "triaged", "reported", "withdrawn"] },
    "operator_reviewed": { "type": "boolean", "default": false },
    "review_history": { "type": "array", "items": { "type": "object" } },

    "recorded_date": { "type": "string", "description": "YYYY-MM-DD; drives the migration gate — findings recorded on/after the policy cutoff (2026-06-25) MUST carry evidence_contract, earlier ones are advisory" },
    "schema_version": { "type": "integer", "description": "2 = evidence-contract era" },
    "evidence_contract": {
      "type": "object",
      "description": "Structured proof-of-rigor. Presence + well-formedness is a NECESSARY (not sufficient) gate checked mechanically by tools/check-conformance.py; the model oracle still adjudicates whether the evidence is TRUE.",
      "additionalProperties": false,
      "required": ["negative_control", "replay", "contamination", "justification", "run_cost"],
      "properties": {
        "negative_control": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ran", "result"],
          "properties": {
            "ran": { "type": "boolean" },
            "result": { "enum": ["refused", "no_signal", "different_outcome", "n/a"], "description": "the control MUST NOT reproduce the finding's signal" },
            "attempt_id": { "type": ["string", "null"] }
          }
        },
        "positive_control": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ran": { "type": "boolean" },
            "result": { "enum": ["detector_fired", "sibling_denied", "n/a"], "description": "proves the oracle CAN detect success / the guard belongs there" },
            "attempt_id": { "type": ["string", "null"] }
          }
        },
        "replay": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sessions", "fresh_session", "deterministic"],
          "properties": {
            "sessions": { "type": "integer", "minimum": 1 },
            "fresh_session": { "type": "boolean", "description": "replayed in a session with no shared memory/cache" },
            "deterministic": { "type": "boolean" }
          }
        },
        "contamination": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ruled_out"],
          "properties": {
            "ruled_out": { "type": "boolean" },
            "sources_checked": { "type": "array", "items": { "enum": ["session_memory", "retrieval_cache", "operator_hinting", "artifact_reuse", "ui_sidechannel"] } }
          }
        },
        "justification": { "type": "string", "description": "the one-sentence prime-directive test — why this is real (or, for a refutation, why it is NOT)" },
        "run_cost": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model_calls", "target_calls"],
          "properties": {
            "model_calls": { "type": "integer", "minimum": 0 },
            "target_calls": { "type": "integer", "minimum": 0 },
            "tokens": { "type": ["integer", "null"], "minimum": 0 },
            "elapsed_seconds": { "type": ["number", "null"], "minimum": 0 }
          }
        },
        "evidence_refs": { "type": "array", "items": { "type": "string" }, "description": "attempt:// transcript:// screenshot:// pointers; never inline secrets" }
      }
    }
  }
}
